  "annotations": { "list": [] },
  "description": "CampusTrade Microservices Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Service Health Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "API Gateway",
      "type": "stat",
      "targets": [{ "expr": "up{job='api-gateway'}", "legendFormat": "Status" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Auth Service",
      "type": "stat",
      "targets": [{ "expr": "up{job='auth-service'}", "legendFormat": "Status" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Listing Service",
      "type": "stat",
      "targets": [{ "expr": "up{job='listing-service'}", "legendFormat": "Status" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
