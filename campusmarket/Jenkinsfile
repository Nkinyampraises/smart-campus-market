pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 60, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '10'))
  }

  environment {
    REGISTRY        = 'praisesn'
    IMAGE_TAG       = "${env.GIT_COMMIT?.take(7) ?: 'latest'}"
    SERVICES_PATH   = 'campusmarket/backend/services'
    SONAR_HOST_URL  = 'http://host.docker.internal:9000'
    K8S_NAMESPACE   = 'campustrade'
    SERVICES        = 'auth-service user-service listing-service chat-service admin-service ai-service search-service notification-service api-gateway'
  }

  stages {

    // ── 1. Checkout ───────────────────────────────────────────────────────────
    stage('Checkout') {
      steps {
        checkout scm
        sh 'git log -1 --format="%H %s"'
      }
    }

    // ── 2. Install Dependencies ───────────────────────────────────────────────
    stage('Install Dependencies') {
      parallel {
        stage('Frontend') {
          steps {
            dir('campusmarket/frontend') {
              sh 'npm install --prefer-offline || npm install'
            }
          }
        }
        stage('Backend Services') {
          steps {
            sh '''
              for svc in $SERVICES; do
                echo "-- Installing $svc"
                (cd $SERVICES_PATH/$svc && npm install --prefer-offline) || true
              done
            '''
          }
        }
      }
    }

    // ── 3. Run Tests + Coverage ───────────────────────────────────────────────
    stage('Test') {
      steps {
        sh '''
          for svc in auth-service user-service listing-service notification-service chat-service search-service ai-service; do
            if [ -f "$SERVICES_PATH/$svc/package.json" ]; then
              echo "===== Testing $svc ====="
              (cd $SERVICES_PATH/$svc && npm test -- --coverage --watchAll=false --forceExit \
                --coverageReporters=lcov --coverageReporters=text-summary 2>&1) || true
            fi
          done
        '''
      }
      post {
        always {
          publishHTML([
            allowMissing: true,
            reportDir: 'campusmarket/backend/services/auth-service/coverage/lcov-report',
            reportFiles: 'index.html',
            reportName: 'Coverage Report'
          ])
        }
      }
    }

    // ── 4. SonarQube Analysis ─────────────────────────────────────────────────
    stage('SonarQube Analysis') {
      steps {
        script {
          // Get token from Jenkins credentials if configured
          def sonarToken = ''
          try {
            withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TKN')]) {
              sonarToken = env.SONAR_TKN
            }
          } catch(e) {
            echo "SonarQube token not configured in Jenkins yet - running without auth"
          }

          def tokenFlag = sonarToken ? "-Dsonar.token=${sonarToken}" : ""

          sh """
            which sonar-scanner || { echo "sonar-scanner not found, skipping SonarQube"; exit 0; }

            # Check SonarQube is reachable
            curl -sf ${SONAR_HOST_URL}/api/system/status 2>/dev/null || { echo "SonarQube not reachable at ${SONAR_HOST_URL}, skipping"; exit 0; }

            echo "SonarQube is UP — running analysis..."

            for svc in auth-service user-service listing-service notification-service chat-service; do
              if [ -d "$SERVICES_PATH/\$svc" ]; then
                echo "=== Scanning \$svc ==="
                (cd $SERVICES_PATH/\$svc && sonar-scanner \\
                  -Dsonar.projectKey=campustrade-\${svc} \\
                  -Dsonar.projectName="CampusTrade \${svc}" \\
                  -Dsonar.projectVersion=1.0 \\
                  -Dsonar.sources=. \\
                  -Dsonar.exclusions="node_modules/**,coverage/**,**/*.test.js" \\
                  -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \\
                  -Dsonar.host.url=${SONAR_HOST_URL} \\
                  ${tokenFlag}) || true
              fi
            done

            # Frontend
            (cd campusmarket/frontend && sonar-scanner \\
              -Dsonar.projectKey=campustrade-frontend \\
              -Dsonar.projectName="CampusTrade Frontend" \\
              -Dsonar.projectVersion=1.0 \\
              -Dsonar.sources=src \\
              -Dsonar.exclusions="node_modules/**,dist/**,**/*.test.jsx" \\
              -Dsonar.host.url=${SONAR_HOST_URL} \\
              ${tokenFlag}) || true
          """
        }
      }
    }

    // ── 5. Quality Gate ───────────────────────────────────────────────────────
    stage('Quality Gate') {
      steps {
        script {
          try {
            timeout(time: 3, unit: 'MINUTES') {
              waitForQualityGate abortPipeline: false
            }
          } catch (e) {
            echo "Quality gate skipped: ${e.message}"
          }
        }
      }
    }

    // ── 6. Build Docker Images ────────────────────────────────────────────────
    stage('Build Docker Images') {
      steps {
        dir('campusmarket/backend') {
          sh '''
            for svc in $SERVICES; do
              echo "Building campustrade/$svc:$IMAGE_TAG"
              docker build \
                --build-arg SERVICE_NAME=$svc \
                -t campustrade/$svc:$IMAGE_TAG \
                -t campustrade/$svc:latest \
                . && echo "OK: $svc" || echo "SKIP: $svc"
            done
          '''
        }
        dir('campusmarket/frontend') {
          sh '''
            npm run build || true
          '''
        }
      }
    }

    // ── 7. Deploy to Kubernetes ───────────────────────────────────────────────
    stage('Deploy to Kubernetes') {
      steps {
        sh '''
          # Check kubectl
          kubectl version --client 2>/dev/null || { echo "kubectl not found, skipping K8s deploy"; exit 0; }

          # Check cluster connection
          kubectl cluster-info 2>/dev/null || { echo "No K8s cluster, skipping deploy"; exit 0; }

          echo "Deploying to Kubernetes..."

          kubectl apply -f campusmarket/backend/k8s/namespace.yml || true
          kubectl apply -f campusmarket/backend/k8s/configmap.yml || true
          kubectl apply -f campusmarket/backend/k8s/secret.yml    || true
          kubectl apply -f campusmarket/backend/k8s/postgres.yml  || true
          kubectl apply -f campusmarket/backend/k8s/redis.yml     || true

          for svc in $SERVICES; do
            if [ -f "campusmarket/backend/k8s/$svc.yml" ]; then
              kubectl apply -f campusmarket/backend/k8s/$svc.yml -n $K8S_NAMESPACE || true
              kubectl set image deployment/$svc $svc=campustrade/$svc:$IMAGE_TAG -n $K8S_NAMESPACE 2>/dev/null || true
            fi
          done

          kubectl apply -f campusmarket/backend/k8s/ingress.yml -n $K8S_NAMESPACE || true

          echo "Kubernetes deployment complete"
          kubectl get pods -n $K8S_NAMESPACE 2>/dev/null || true
        '''
      }
    }

    // ── 8. Smoke Test ─────────────────────────────────────────────────────────
    stage('Smoke Test') {
      steps {
        sh '''
          curl -sf http://localhost:8080/health && echo "Gateway: OK" || echo "Gateway: not reachable from CI"
        '''
      }
    }
  }

  post {
    success {
      echo "SUCCESS — Build #${BUILD_NUMBER} | ${IMAGE_TAG}"
    }
    failure {
      echo "FAILED — Build #${BUILD_NUMBER}"
    }
    always {
      cleanWs()
    }
  }
}
