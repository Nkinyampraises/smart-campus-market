pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '20'))
    timeout(time: 90, unit: 'MINUTES')
  }

  parameters {
    booleanParam(
      name: 'DEPLOY_TO_VPS',
      defaultValue: true,
      description: 'Deploy a verified main-branch release to the production K3s VPS.'
    )
    booleanParam(
      name: 'RUN_SONARQUBE',
      defaultValue: true,
      description: 'Analyze the repository and enforce the SonarQube quality gate.'
    )
  }

  triggers {
    pollSCM('H/5 * * * *')
  }

  environment {
    NODE_IMAGE = 'node:20-alpine'
    CI_COMPOSE_PROJECT_NAME = 'campusmarket-ci'
    DEPLOY_COMPOSE_PROJECT_NAME = 'campusmarket'
    COMPOSE_FILE = 'backend/docker-compose.prod.yml'
    DEPLOY_ROOT = '/srv/campustrade'
    SONAR_HOST_URL = 'http://127.0.0.1:9000'
    SONAR_SCANNER_IMAGE = 'sonarsource/sonar-scanner-cli:12.1.0.3233_8.0.1'
    KUBECTL_IMAGE = 'registry.k8s.io/kubectl:v1.36.1'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('System Information') {
      steps {
        dir('campusmarket') {
          script {
            def summary = sh(
              script: 'bash backend/scripts/generate-system-information.sh ci-reports',
              returnStdout: true
            ).trim()
            currentBuild.description = summary.take(240)
          }
        }
      }
    }

    stage('Validate Configuration') {
      steps {
        dir('campusmarket') {
          sh '''
            docker compose \
              -p "$CI_COMPOSE_PROJECT_NAME" \
              --env-file backend/.env.example \
              -f "$COMPOSE_FILE" \
              config --quiet

            docker run --rm \
              --user "$(id -u):$(id -g)" \
              -v "$PWD:/workspace" \
              -w /workspace \
              "$KUBECTL_IMAGE" \
              kustomize k8s/base >/tmp/campustrade-kubernetes.yaml

            test "$(grep -c '^kind: Deployment$' /tmp/campustrade-kubernetes.yaml)" -ge 12
          '''
        }
      }
    }

    stage('Frontend Quality Gate') {
      steps {
        dir('campusmarket') {
          sh '''
            docker run --rm \
              --user "$(id -u):$(id -g)" \
              -e npm_config_cache=/tmp/npm-cache \
              -v "$PWD:/workspace" \
              -w /workspace/frontend \
              "$NODE_IMAGE" \
              sh -lc 'npm ci && npm run lint && npm test && npm audit --omit=dev --audit-level=high'
          '''
        }
      }
    }

    stage('Backend Quality Gate') {
      steps {
        dir('campusmarket') {
          sh '''
            docker run --rm \
              --user "$(id -u):$(id -g)" \
              -e npm_config_cache=/tmp/npm-cache \
              -v "$PWD:/workspace" \
              -w /workspace \
              "$NODE_IMAGE" \
              sh -lc 'npm run install:backend && npm run build:backend && npm run test:backend && npm run coverage:backend && npm run audit:backend'

            test -s coverage/lcov.info
            grep -q '^SF:backend/services/' coverage/lcov.info
          '''
        }
      }
    }

    stage('SonarQube Quality Gate') {
      when {
        expression { params.RUN_SONARQUBE }
      }
      steps {
        withCredentials([string(credentialsId: 'campustrade-sonar-token', variable: 'SONAR_TOKEN')]) {
          dir('campusmarket') {
            sh '''
              curl --fail --silent --show-error \
                --retry 12 --retry-delay 5 --retry-connrefused \
                "$SONAR_HOST_URL/api/system/status" >/dev/null

              docker run --rm \
                --network host \
                --user "$(id -u):$(id -g)" \
                --tmpfs /tmp:rw,exec,nosuid,nodev,size=1536m,mode=1777 \
                -e SONAR_HOST_URL \
                -e SONAR_TOKEN \
                -e SONAR_USER_HOME=/tmp/.sonar \
                -v "$PWD:/usr/src" \
                -w /usr/src \
                "$SONAR_SCANNER_IMAGE" \
                -Dsonar.qualitygate.wait=true \
                -Dsonar.qualitygate.timeout=300
            '''
          }
        }
      }
    }

    stage('Build Production Images') {
      steps {
        dir('campusmarket') {
          sh '''
            build_images() {
              docker compose \
                -p "$CI_COMPOSE_PROJECT_NAME" \
                --env-file backend/.env.example \
                -f "$COMPOSE_FILE" \
                build "$@"
            }

            if ! build_images --pull; then
              echo 'Initial BuildKit build failed; clearing build cache and retrying once.' >&2
              docker builder prune --all --force
              build_images --pull --no-cache
            fi
          '''
        }
      }
    }

    stage('Container Security Gate') {
      steps {
        dir('campusmarket') {
          sh '''
            frontend_image="${CI_COMPOSE_PROJECT_NAME}-frontend:latest"
            if docker run --rm "$frontend_image" sh -ec \
              "grep -R -E -q '(your-frontend-domain\\.com|http://localhost:8080)' \
                /usr/share/nginx/html/index.html /usr/share/nginx/html/assets"
            then
              echo 'Frontend image contains a non-production API placeholder.' >&2
              exit 1
            fi
            echo 'Frontend runtime configuration gate passed.'

            for service in \
              frontend api-gateway auth-service user-service listing-service \
              chat-service admin-service ai-service search-service notification-service
            do
              image_ref="${CI_COMPOSE_PROJECT_NAME}-${service}:latest"
              docker image inspect "$image_ref" >/dev/null

              docker run --rm \
                -v /var/run/docker.sock:/var/run/docker.sock \
                -v campustrade-trivy-cache:/root/.cache \
                aquasec/trivy:0.72.0 \
                image \
                --scanners vuln \
                --severity CRITICAL \
                --ignore-unfixed \
                --skip-version-check \
                --format json \
                --output /tmp/trivy-result.json \
                --exit-code 1 \
                "$image_ref"
              echo "Security scan passed: $service"
            done
          '''
        }
      }
    }

    stage('Deploy Production K3s') {
      when {
        allOf {
          expression {
            env.BRANCH_NAME == 'main' ||
              env.GIT_BRANCH == 'main' ||
              env.GIT_BRANCH == 'origin/main'
          }
          // Jenkins may not expose a newly declared parameter until the next
          // run. Treat that first-run null as the secure production default.
          expression { params.DEPLOY_TO_VPS == null || params.DEPLOY_TO_VPS }
        }
      }
      steps {
        withCredentials([file(credentialsId: 'campustrade-prod-env', variable: 'PROD_ENV_FILE')]) {
          dir('campusmarket') {
            sh '''
              test -d "$DEPLOY_ROOT"
              test -w "$DEPLOY_ROOT/current"
              mkdir -p "$DEPLOY_ROOT/current" "$DEPLOY_ROOT/backups" "$DEPLOY_ROOT/evidence"
              # Existing release directories are root-owned and group-writable.
              # Copy content and links without attempting privileged metadata changes.
              rsync -rl --delete \
                --exclude '.git' \
                --exclude 'node_modules' \
                --exclude 'coverage' \
                --exclude 'backend/.env' \
                ./ "$DEPLOY_ROOT/current/"
              install -m 640 "$PROD_ENV_FILE" "$DEPLOY_ROOT/current/backend/.env"

              cd "$DEPLOY_ROOT/current"
              chmod 750 k8s/scripts/*.sh backend/scripts/*.sh
              release_tag="${GIT_COMMIT:-build-$BUILD_NUMBER}"
              release_tag="$(printf '%s' "$release_tag" | cut -c1-12)"

              SKIP_BUILD=true \
                SOURCE_PROJECT="$CI_COMPOSE_PROJECT_NAME" \
                IMAGE_TAG="$release_tag" \
                ENV_FILE=backend/.env \
                bash k8s/scripts/build-and-import-images.sh

              cutover_marker="$DEPLOY_ROOT/k3s-cutover-complete"
              if [ ! -f "$cutover_marker" ]; then
                IMAGE_TAG="$release_tag" ENV_FILE=backend/.env \
                  bash k8s/scripts/migrate-and-cutover.sh
                date -u +'%Y-%m-%dT%H:%M:%SZ' >"$cutover_marker"
              else
                IMAGE_TAG="$release_tag" ENV_FILE=backend/.env \
                  bash k8s/scripts/deploy.sh full
                BASE_URL=http://127.0.0.1 bash backend/scripts/smoke-test-running.sh
              fi

              docker compose \
                -p "$DEPLOY_COMPOSE_PROJECT_NAME" \
                --env-file backend/.env \
                -f "$COMPOSE_FILE" \
                up -d sonar-db sonarqube

              for attempt in $(seq 1 60); do
                sonar_status="$(curl -fsS http://127.0.0.1:9000/api/system/status 2>/dev/null | jq -r '.status // empty' || true)"
                [ "$sonar_status" = UP ] && break
                sleep 5
              done
              [ "${sonar_status:-}" = UP ]

              BUILD_NUMBER="$BUILD_NUMBER" \
                EVIDENCE_DIR="$WORKSPACE/evidence/build-$BUILD_NUMBER" \
                bash k8s/scripts/capture-evidence.sh
            '''
          }
        }
      }
    }
  }

  post {
    always {
      script {
        if (fileExists('campusmarket/backend/scripts/generate-system-information.sh')) {
          dir('campusmarket') {
            def summary = sh(
              script: 'bash backend/scripts/generate-system-information.sh ci-reports',
              returnStdout: true
            ).trim()
            currentBuild.description = summary.take(240)
          }
        }
      }
      archiveArtifacts(
        artifacts: 'campusmarket/frontend/dist/**,campusmarket/coverage/**,campusmarket/evidence/**,campusmarket/ci-reports/**,campusmarket/backend/RELEASE_GATE_CHECKLIST.md,campusmarket/backend/PRODUCTION.md,campusmarket/docs/**',
        allowEmptyArchive: true,
        fingerprint: true
      )
      deleteDir()
    }
  }
}
