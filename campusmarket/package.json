{
  "name": "campus-trade",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "install:backend": "node scripts/service-task.js install",
    "install:all": "npm run install:frontend && npm run install:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "node scripts/service-task.js build",
    "build:all": "npm run build:frontend && npm run build:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "node scripts/service-task.js test",
    "test:all": "npm run test:frontend && npm run test:backend",
    "start:dev": "docker-compose -f docker/docker-compose.yml up -d",
    "stop:dev": "docker-compose -f docker/docker-compose.yml down"
  }
}
