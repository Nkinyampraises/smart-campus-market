# Infrastructure
DB_HOST=localhost
DB_PORT=5432
DB_USER=campustrade
DB_PASSWORD=change_me
DB_NAME=campustrade
DB_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# Security
JWT_SECRET=change_this_to_a_random_64_char_string
NPM_CONFIG_STRICT_SSL=true
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@campustrade.cm

# Web push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=replace_with_public_vapid_key
VAPID_PRIVATE_KEY=replace_with_private_vapid_key
VAPID_EMAIL=mailto:admin@example.com

# Frontend
FRONTEND_URL=https://your-frontend-domain.com

# Internal service URLs (compose/k8s)
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
LISTING_SERVICE_URL=http://listing-service:3003
CHAT_SERVICE_URL=http://chat-service:3004
ADMIN_SERVICE_URL=http://admin-service:3005
AI_SERVICE_URL=http://ai-service:3006
SEARCH_SERVICE_URL=http://search-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3008

# Monitoring
GRAFANA_USER=campusadmin
GRAFANA_PASS=change_this_to_a_random_32_char_string
