# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────
dist/
build/
.next/
out/

# ── Test coverage reports (generated — do not commit) ─────
coverage/
*.lcov
lcov.info

# ── SonarQube scanner work files (generated) ──────────────
.scannerwork/

# ── Environment files (secrets — never commit) ────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code settings (local only) ─────────────────────
.claude/

# ── Docker ────────────────────────────────────────────────
.dockerignore

# ── Misc ──────────────────────────────────────────────────
*.tgz
*.zip
.cache/
tmp/
temp/
